# -----------------------------------------------------------------------------
# Mise packages
# -----------------------------------------------------------------------------

# Applies to any OS type.
export PACKAGES_MISE=(
    # core runtime environments
    "go"
    "helm"
    "helmfile"
    "lua"
    "node"
    "python"
    "rust"
)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Install configs
# -----------------------------------------------------------------------------

export SYMLINK_CONFIG=(
    "lazygit"
)

# Check if zellij is installed
if command_exists "zellij"; then
    SYMLINK_CONFIG+=("zellij")
else
    case "$OS_TYPE" in
        darwin)
            for pkg in "${PACKAGES_BREW[@]}"; do
                if [ "${pkg}" == "zellij" ]; then
                    SYMLINK_CONFIG+=("zellij")
                fi
            done
            ;;
        linux)
            for pkg in "${PACKAGES_PACMAN[@]}"; do
                if [ "${pkg}" == "zellij" ]; then
                    SYMLINK_CONFIG+=("zellij")
                fi
            done
            ;;
        *) ;;
    esac
fi

export SYMLINK_CONFIG_GUI=(
)
# -----------------------------------------------------------------------------
