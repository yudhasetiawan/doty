#!/usr/bin/env bash

# -----------------------------------------------------------------------------
# Personalization
# -----------------------------------------------------------------------------

# If you define these, they will get used instead of prompting you for them.
# This config being used to setup SSH and GPG keys.
export REAL_NAME=
export REAL_EMAIL=
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Graphical User Interface (GUI)
# -----------------------------------------------------------------------------

# When set to "yes", niri and graphical apps will be installed.
# 
# NOTE: This only applicable for Arch based Linux distro and always skipped in WSL,
#       and containers.
export DOTY_GUI_ENABLED="yes"
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Most known commons directories
# -----------------------------------------------------------------------------

# If you ever want to change them then change them here, they will get written
# to the correct files from this script, there's a few spots!
#
# I use the defaults and I suggest you do the same, here's the source:
#     https://specifications.freedesktop.org/basedir/latest/
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${zdot}/.cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${zdot}/.config}"
export XDG_BIN_HOME="${XDG_BIN_HOME:-${zdot}/.local/bin}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${zdot}/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-${zdot}/.local/state}"

# Most of these have customized defaults, here's the source with defaults:
#     https://wiki.archlinux.org/title/XDG_user_directories
#
# Some people thought process is if a program writes something to pictures,
# videos or most other directories listed below it's probably a temporary
# location because they would organize where the file will live permanently
# afterwards.
export XDG_DESKTOP_DIR="${XDG_DESKTOP_DIR:-${zdot}/Desktop}"
export XDG_DOCUMENTS_DIR="${XDG_DOCUMENTS_DIR:-${zdot}/Documents}"
export XDG_DOWNLOAD_DIR="${XDG_DOWNLOAD_DIR:-${zdot}/Downloads}"
export XDG_MUSIC_DIR="${XDG_MUSIC_DIR:-${zdot}/Music}"
export XDG_PICTURES_DIR="${XDG_PICTURES_DIR:-${zdot}/Pictures}"
export XDG_PROJECTS_DIR="${XDG_PROJECTS_DIR:-${zdot}/Projects}"
export XDG_PUBLICSHARE_DIR="${XDG_PUBLICSHARE_DIR:-${zdot}/Public}"
export XDG_TEMPLATES_DIR="${XDG_TEMPLATES_DIR:-${zdot}/Templates}"
export XDG_VIDEOS_DIR="${XDG_VIDEOS_DIR:-${zdot}/Videos}"

# TODO: Need to be removed and use known XDG directories instead.
export DOTFILES_LOCAL_DIRECTORY="${DOTFILES_LOCAL_DIRECTORY:-${DOTY}/.local}"
export DOTY_DEVELOPMENT_DIRECTORY="${DOTY_DEVELOPMENT_DIRECTORY:-${XDG_DATA_HOME}}"
export DOTY_DEVELOPMENT_CONFIG_DIRECTORY="${DOTY_DEVELOPMENT_CONFIG_DIRECTORY:-${DOTY_DEVELOPMENT_DIRECTORY}/config}"
export DOTY_DEVELOPMENT_CACHE_DIRECTORY="${DOTY_DEVELOPMENT_CACHE_DIRECTORY:-${DOTY_DEVELOPMENT_DIRECTORY}/cache}"
export DOTY_DEVELOPMENT_SDK_DIRECTORY="${DOTY_DEVELOPMENT_SDK_DIRECTORY:-${DOTY_DEVELOPMENT_DIRECTORY}/sdks}"

# -----------------------------------------------------------------------------

