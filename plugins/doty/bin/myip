#!/usr/bin/env bash

# Prints and / or copies your local / public IP address.
#
# Examples:
#   myip     # Prints both your local and public IP address
#   myip -l  # Prints your local IP address
#   myip -p  # Prints your public IP address

set -o errexit
set -o pipefail
set -o nounset

flag="${1:-}"

local_ip() {
    if [[ "${OSTYPE}" == linux-* ]]; then
        # \K matches on 'src ' but doesn't return it in the output.
        ip route get 1.1.1.1 | grep --only-matching --perl-regexp "src \K[^ ]+"
    else
        ipconfig getifaddr "$(route -n get 1.1.1.1 | awk '/interface:/{print $2}')"
    fi
}

public_ip() {
    local suffix="json"
    if [ $# -ne 0 ]; then
        suffix="$1/json"
    fi

    local response=$(curl --fail --ipv4 --max-time 3 -s https://ipinfo.io/json) # https://ifconfig.me

    echo "Public IP:    $(echo "$response" | jq -r '.ip')"
    echo "Location:     $(echo "$response" | jq '{loc: (.city + ", " +.region)}' | jq -r '.loc')"
    echo "Organization: $(echo "$response" | jq -r '.org')"
}

case "${flag:-}" in
-l | --local)
    local_ip
    ;;
-p | --public)
    public_ip
    echo
    ;;
"")
    printf "Local IP: %s\n\n%s\n" "$(local_ip)" "$(public_ip)"
    ;;
*)
    echo "'${flag}' is an invalid flag, please use: -l or -p" >&2
    exit 1
    ;;
esac
